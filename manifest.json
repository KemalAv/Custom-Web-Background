{
  "manifest_version": 3,
  "name": "Custom Web Background",
  "version": "3.63",
  "description": "Tired of boring plain pages? This extension lets you add your own wallpaper behind every website you visit.",
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "video-bg.html",
        "video-bg.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}